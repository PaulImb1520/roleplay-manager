---
import { ChatView } from "@/components/conversation/chat-view"
import { getConversation } from "@/lib/api/conversations"
import BaseLayout from "@/layouts/base.astro"
import type { ConversationDetail } from "@workspace/shared/types/conversation"

export const prerender = false

const { id } = Astro.params

let conversation: ConversationDetail | null = null
let error: string | null = null

if (id) {
  try {
    conversation = await getConversation(id)
  } catch (e) {
    error = e instanceof Error ? e.message : "Error desconocido"
  }
}
---

<BaseLayout
  title={
    conversation
      ? `${conversation.title ?? conversation.characterName} - Roleplay Manager`
      : "Conversación no encontrada"
  }
>
  {
    conversation ? (
      <div className="flex h-[calc(100vh-8rem)] flex-col rounded-lg border">
        <ChatView client:load conversation={conversation} />
      </div>
    ) : (
      <div className="flex items-center justify-center p-12 text-sm text-muted-foreground">
        {error ?? "Conversación no encontrada."}
      </div>
    )
  }
</BaseLayout>
